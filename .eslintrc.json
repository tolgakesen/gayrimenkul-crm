{
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-undef": "warn",
    "eqeqeq": ["warn", "smart"],
    "no-var": "error",
    "prefer-const": "warn",
    "no-duplicate-imports": "error"
  }
}
